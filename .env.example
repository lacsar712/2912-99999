# 环境变量配置示例
# 复制此文件为 .env 并修改配置

# 数据库配置
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=production_system

# JWT配置
SECRET_KEY=your-secret-key-change-in-production

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# 日志配置
LOG_LEVEL=INFO

# Flask配置
FLASK_ENV=development